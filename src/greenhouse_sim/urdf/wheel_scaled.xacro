<?xml version="1.0"?>
<!--
  wheel_scaled.xacro — uniform-scale fork of
  src/simulations/robot_gazebo/urdf/wheel.xacro (vendor, do-not-modify).

  Defines the functional (driven, continuous) mecanum wheels as primitive
  cylinders. Radius/length, mount positions and joint height are scaled by ${S}
  (defined in robot_scaled.gazebo.xacro). Mass scales S**3, inertia S**5.
  Joint NAMES (front_left_joint ...) are kept identical so the MecanumDrive
  plugin still binds to them. The vendor `<kp>1000000000.0.0</kp>` typo (two
  decimal points) is corrected here to a valid number.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================== -->
  <xacro:property name="WHEEL_RADIUS" value="${0.04*S}" />
  <xacro:property name="WHEEL_LENGTH" value="${0.025*S}" />
  <xacro:property name="WHEEL_VISUAL_ENABLE" value="true" />

  <!-- ============================================== -->
  <xacro:macro name="mecanum_wheel" params="name x y">
    <link name="${name}_link">

      <xacro:if value="${WHEEL_VISUAL_ENABLE}">
        <visual>
          <geometry><cylinder radius="${WHEEL_RADIUS}" length="${WHEEL_LENGTH}"/></geometry>
          <material name="black"><color rgba="0 0 0 1"/></material>
          <origin rpy="1.5707 0 0"/>
        </visual>
      </xacro:if>

      <collision>
        <geometry><cylinder radius="${WHEEL_RADIUS}" length="${WHEEL_LENGTH}"/></geometry>
        <origin rpy="1.5707 0 0"/>
      </collision>

      <inertial>
        <mass value="2.0"/>
        <inertia ixx="${0.0007 * (2.0/10.0) * S**2}" ixy="0" ixz="0" iyy="${0.0007 * (2.0/10.0) * S**2}" iyz="0" izz="${0.0012 * (2.0/10.0) * S**2}"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>

      <origin xyz="${x} ${y} ${0.01*S}"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="1.0" friction="0.5"/>
    </joint>

    <gazebo reference="${name}_link">
      <mu1>10.0</mu1>
      <mu2>10.0</mu2>
      <!-- kp 를 가벼워진 바퀴(2kg)에 맞춰 1e8 로 낮춰 접촉 진동수 √(kp/m) 를
           원본(10kg·kp=1e9)과 같은 수준으로 복원 → 접촉 jitter/RTF 요동 억제. -->
      <kp>100000000.0</kp>
      <kd>10000.0</kd>
      <minDepth>0.0001</minDepth>
    </gazebo>
  </xacro:macro>

  <!-- ============================================== -->
  <xacro:mecanum_wheel name="front_left"  x="${0.08*S}"  y="${0.09*S}"/>
  <xacro:mecanum_wheel name="front_right" x="${0.08*S}"  y="${-0.09*S}"/>
  <xacro:mecanum_wheel name="rear_left"   x="${-0.08*S}" y="${0.09*S}"/>
  <xacro:mecanum_wheel name="rear_right"  x="${-0.08*S}" y="${-0.09*S}"/>

</robot>
